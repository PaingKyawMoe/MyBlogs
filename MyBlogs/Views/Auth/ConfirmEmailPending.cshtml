@model string

@{
    ViewData["Title"] = "Verify Your Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm p-4">
                <h2 class="mb-4">Enter Verification Code</h2>
                <p>We've sent a 6-digit code to your email.</p>

                <form asp-controller="Auth" asp-action="ConfirmEmailByCode" method="post">
                    <input type="hidden" name="email" value="@Model" />

                    <div class="form-group mb-3">
                        <label>Email Address</label>
                        <input type="email" class="form-control" value="@Model" disabled />
                    </div>
                    
                    <div class="form-group mb-3">
                        <label>Verification Code</label>
                        <input type="text" name="code" class="form-control" placeholder="Enter 6-digit code" maxlength="6" required />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Verify Account</button>
                </form>
            </div>
        </div>
    </div>
</div>